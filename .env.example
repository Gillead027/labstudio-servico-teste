# Porta local usada pelo backend/API e pelo bot quando rodar em servidor persistente.
PORT=3001

# URL publica do projeto Supabase usada pelo backend.
SUPABASE_URL=https://seu-projeto.supabase.co

# Chave publica anon do Supabase, segura para exemplos e uso no frontend quando necessario.
SUPABASE_ANON_KEY=sua_chave_publica_anon_do_supabase

# Chave service role do Supabase: use somente no backend/VPS, nunca em HTML, JS publico ou variaveis expostas no frontend.
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_apenas_no_servidor

# Numero WhatsApp que recebe notificacoes internas de novos agendamentos.
BOT_NOTIFY_NUMBER=5527999999999

# URL publica do site usado pelos jovens/equipe, normalmente o dominio da Vercel em producao.
PUBLIC_SITE_URL=https://labstudio-exemplo.vercel.app

# URL publica do backend persistente onde o bot/API rodam, sempre com HTTPS em producao.
PUBLIC_BOT_URL=https://bot.labstudio-exemplo.com

# Origens autorizadas no CORS; separe multiplos dominios por virgula.
ALLOWED_ORIGINS=https://labstudio-exemplo.vercel.app,https://www.labstudio-exemplo.com

# Token forte obrigatorio para proteger a pagina do QR/pairing do WhatsApp.
QR_PAGE_TOKEN=troque-por-um-token-forte-do-qr

# Token forte obrigatorio para rotas internas/manuais protegidas do backend.
INTERNAL_API_TOKEN=troque-por-um-token-interno-forte

# Caminho do Chrome/Chromium no servidor persistente; deixe vazio em localhost se Puppeteer resolver sozinho.
PUPPETEER_EXECUTABLE_PATH=

# Pasta persistente da sessao do WhatsApp LocalAuth; precisa sobreviver a reinicios do bot.
WWEBJS_AUTH_PATH=.wwebjs_auth

# Identificador da sessao do WhatsApp; use bot-crj se quiser reaproveitar a estrutura do repo antigo.
WHATSAPP_CLIENT_ID=labstudio-servico-teste

# Ambiente da configuracao do LabStudio lida no Supabase.
LABSTUDIO_CONFIG_ENV=producao
